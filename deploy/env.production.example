# /etc/nine-universe.env にコピーして権限を絞る: sudo chmod 600 /etc/nine-universe.env
# systemd の EnvironmentFile= で読み込む

SPRING_PROFILES_ACTIVE=production

# PostgreSQL（本番では必ず強いパスワードに変更）
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/nineuniverse
SPRING_DATASOURCE_USERNAME=nineuniverse
SPRING_DATASOURCE_PASSWORD=ここに強いパスワード

# 任意: JVM メモリ（1GB VPS なら例）
# JAVA_OPTS=-Xms128m -Xmx384m
