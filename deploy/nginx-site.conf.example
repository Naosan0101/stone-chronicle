# /etc/nginx/sites-available/nine-universe に置き、sites-enabled へ symlink
# certbot --nginx 実行後、listen 443 と ssl_* が追加される

upstream nine_universe_app {
	server 127.0.0.1:8080;
}

server {
	listen 80;
	listen [::]:80;
	server_name nine-universe.jp www.nine-universe.jp;

	client_max_body_size 20m;
	proxy_read_timeout 120s;

	location / {
		proxy_pass http://nine_universe_app;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
	}
}
