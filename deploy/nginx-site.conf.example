# /etc/nginx/sites-available/nine-universe に置き、sites-enabled へ symlink
# certbot で SSL 取得後、listen 443 と ssl_* 行が追加されることが多い

upstream nine_universe_app {
	server 127.0.0.1:8080;
}

server {
	server_name nine-universe.jp www.nine-universe.jp;

	location / {
		proxy_pass http://nine_universe_app;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
	}
}
