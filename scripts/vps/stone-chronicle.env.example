# /etc/stone-chronicle.env にコピーして値を設定（chmod 600 推奨）
# systemd の unit でも SPRING_PROFILES_ACTIVE=production を付与済み（application-production.properties）
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/springdb
SPRING_DATASOURCE_USERNAME=springuser
SPRING_DATASOURCE_PASSWORD=ここにSTONE_DB_PASSWORDと同じ値
